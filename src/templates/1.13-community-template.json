        "outbound": "Default"
      },
      {
        "protocol": "quic",
        "action": "reject"
      },
      {
        "protocol": "bittorrent",
        "outbound": "Direct-Out"
      },
      {
        "port": [
          5201
        ],
        "outbound": "Direct-Out"
      },
      {
        "domain_suffix": [
          "ottiptv.cc"
        ],
        "outbound": "Direct-Out"
      },
      {
        "domain_suffix": [
          "uhdnow.com"
